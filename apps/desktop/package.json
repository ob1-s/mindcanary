{
  "name": "@mindcanary/desktop",
  "version": "0.1.2",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "vite",
    "format": "prettier --write src index.html vite.config.ts src-tauri/tauri.conf.json src-tauri/capabilities",
    "format:check": "prettier --check src index.html vite.config.ts src-tauri/tauri.conf.json src-tauri/capabilities",
    "lint": "eslint src",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "vitest run"
  },
  "dependencies": {
    "@mindcanary/protocol": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  }
}
