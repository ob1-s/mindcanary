{
  "manifest_version": 3,
  "name": "MindCanary",
  "version": "0.1.2",
  "description": "Local-first personal rhythm collection without browsing content.",
  "minimum_chrome_version": "120",
  "permissions": ["alarms", "nativeMessaging", "storage"],
  "optional_permissions": ["idle", "scripting"],
  "optional_host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "MindCanary status",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}
